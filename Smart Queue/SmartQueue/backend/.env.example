# Backend Configuration
PORT=5000

# MongoDB Connection (local or Atlas)
# Local: mongodb://127.0.0.1:27017/smartqueue
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/smartqueue
MONGO_URI=mongodb://127.0.0.1:27017/smartqueue

# JWT Configuration (change to a long random secret in production)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=*
